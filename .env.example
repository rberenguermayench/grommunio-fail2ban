# Copy this file to .env and adjust it for each server.

# Trusted proxy/server IP or CIDR for nginx set_real_ip_from.
# If empty, the deploy script tries to detect the public IP.
REAL_IP_FROM=

# Fail2ban notification settings used in jail.d/grommunio.local.
FAIL2BAN_DESTEMAIL=postmaster@example.com
FAIL2BAN_SENDER=fail2ban-grommunio@example.com

# Set to 1 for unattended deploys.
SKIP_EDIT=1
SKIP_WATCH=1
